library(mgcv)
ordered_chroms <- sort(top_23_chroms)

# 用排好序的 ordered_chroms 作为 levels，这样 facet_wrap 画图时就会按这个顺序排版
plot_data$CHROM <- factor(plot_data$CHR, levels = ordered_chroms)
# ---------------------------------------------------------
# 极速秘诀 1：随机抽样 (Downsampling)
# 我们只随机抽取 5% 的 SNP 来画趋势线，这对宏观趋势毫无影响，但速度起飞！
# ---------------------------------------------------------
# set.seed(42) # 设置随机种子，保证每次抽样结果一样
# plot_data_fast <- plot_data %>% sample_frac(0.05) 
# plot_data_fast
# ---------------------------------------------------------
# 极速秘诀 2：换用 GAM 算法
# ---------------------------------------------------------
p <- ggplot(plot_data, aes(x = POS / 1e6, y = Call_Rate, color = Species)) +
  # 把 method 从 "loess" 改成 "gam"，并指定平滑公式
  geom_smooth(method = "gam", formula = y ~ s(x, bs = "cs"), se = FALSE, size = 1) +
  facet_wrap(~ CHROM, scales = "free_x", ncol = 5) +
  scale_color_manual(values = c("Green Ash (FRAPEN)" = "#56B4E9", 
                                "White Ash (FRAAME)" = "#E69F00")) +
  theme_bw() +
  labs(title = "Whole-Genome Mapping Distribution: White vs. Green Ash",
       subtitle = "Smoothed Call Rate (GAM method, 5% downsampled)",
       x = "Genomic Position (Megabases, Mb)",
       y = "Mean Call Rate") +
  theme(legend.position = "top",
        legend.title = element_blank(),
        axis.text.x = element_text(angle = 45, hjust = 1, size = 6), 
        strip.text = element_text(size = 8, face = "bold"))
p
ggsave("Total_Filtered_missing30_mapping_23Chr_allsnps.pdf", plot = p, width = 16, height = 12, dpi = 300)
