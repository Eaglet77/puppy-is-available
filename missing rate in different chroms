#generate individual list of each species
grep "^FRAAME" Total_Filtered_missing50.imiss | awk '{print $1}' > white_inds.txt
#calculate the missing rate of sites in this species
vcftools --vcf Total_Filtered_missing50.recode.vcf --keep white_inds.txt --missing-site --out Total_Filtered_missing50_white


##plot in R 📸
library(ggplot2)
library(dplyr)

# 1. 读取数据并计算检出率
white_site <- read.table("Total_Filtered_missing50_white.lmiss", header=TRUE, stringsAsFactors=FALSE)
green_site <- read.table("Total_Filtered_missing50_green.lmiss", header=TRUE, stringsAsFactors=FALSE)

white_site$Call_Rate <- 1 - white_site$F_MISS
green_site$Call_Rate <- 1 - green_site$F_MISS

white_site$Species <- "White Ash (FRAAME)"
green_site$Species <- "Green Ash (FRAPEN)"

combined_site <- rbind(
  white_site[, c("CHR", "POS", "Call_Rate", "Species")],
  green_site[, c("CHR", "POS", "Call_Rate", "Species")]
)

top_23_chroms <- names(sort(table(combined_site$CHR), decreasing = TRUE)[1:23])
plot_data <- combined_site %>% filter(CHR %in% top_23_chroms)

# 让染色体按 SNP 数量或者名字排序，保持面板整洁
plot_data$CHROM <- factor(plot_data$CHR, levels = top_23_chroms)

